# Server
PORT=5000
NODE_ENV=development

# Supabase PostgreSQL connection string
# Get this from: supabase.com → your project → Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# UPCitemdb API — free tier, no key needed for trial
# Docs: https://devs.upcitemdb.com/
UPCITEMDB_BASE_URL=https://api.upcitemdb.com/prod/trial

# Open Food Facts — completely free, no key needed
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org/api/v2

# CORS — your frontend URL (comma separated if multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
